# 管理员密码（生产环境必须修改为强密码）
ADMIN_PASSWORD=anonyproof_admin_2026

# API 密钥（用于 API 认证，生产环境必须修改）
API_TOKEN=your_api_token_here

# 数据库路径
DATABASE_PATH=./data/anonyproof.db

# 服务器端口
PORT=4000

# 前端端口
NEXT_PUBLIC_PORT=3000

# 环境
NODE_ENV=production

# 日志级别
LOG_LEVEL=info

# 速率限制（每15分钟最大请求数）
RATE_LIMIT_MAX=100

# 通知轮询间隔（毫秒）
NOTIFICATION_POLL_INTERVAL=30000
